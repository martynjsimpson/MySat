    {
        "id": "0370a1a51410027a",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "function 2",
        "func": "let command = String(msg.payload) + \"\\n\";\n\nflow.set(\"custCommand\", command);\n\nmsg.payload = command;\n\nreturn msg;",
