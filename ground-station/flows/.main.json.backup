    {
        "id": "283bee87f27680a3",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "function 1",
        "func": "let interval = Number(msg.payload);\n\nif (!Number.isFinite(interval) || interval < 1) {\n    return null;\n}\n\nflow.set(\"tlmInterval\", interval);\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 320,
        "y": 980,
        "wires": [
            []
        ]
    },
