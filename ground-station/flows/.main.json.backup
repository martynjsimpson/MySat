    {
        "id": "a1ea5ba4421bd12a",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "Packet Log",
        "func": "let packetLog = flow.get(\"packetLog\") || [];\n\npacketLog.unshift({\n    time: msg.time || \"\",\n    packetType: msg.type || \"\",\n    target: msg.target || \"\",\n    parameter: msg.parameter || \"\",\n    value: msg.value || msg.error || \"\",\n    raw: msg.raw || \"\"\n});\n\npacketLog = packetLog.slice(0, 25);\nflow.set(\"packetLog\", packetLog);\n\nreturn {\n    payload: {\n        rows: packetLog\n    }\n};",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 530,
        "y": 40,
        "wires": [
