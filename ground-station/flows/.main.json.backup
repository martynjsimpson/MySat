    {
        "id": "9919dab57debe661",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "Error Log",
        "func": "let errors = flow.get(\"errorLog\") || [];\n\nif (msg.type !== \"ERR\") {\n    return null;\n}\n\nlet newError = {\n    time: msg.time || \"\",\n    error: msg.error || \"\",\n    raw: msg.raw || \"\"\n};\n\nerrors.unshift(newError);\n\n// keep only most recent 50 in memory\nif (errors.length > 50) {\n    errors = errors.slice(0, 50);\n}\n\nflow.set(\"errorLog\", errors);\n\n// only send the new row to the table\nmsg.payload = [newError];\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 40,
        "wires": [
            [
                "7a2f7fe3e9362b46"
            ]
        ]
    },
    {
