    {
        "id": "283bee87f27680a3",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "send TLM Interval",
        "func": "let interval = Number(msg.payload);\n\nif (!Number.isFinite(interval) || interval < 1) {\n    return null;\n}\n\nflow.set(\"tlmInterval\", interval);\n\nmsg.payload = \"SET,TELEMETRY,INTERVAL_S,\" + interval + \"\\n\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 1120,
        "wires": [
            [
                "a407349444f312cf"
            ]
        ]
    },
