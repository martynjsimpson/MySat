        "format": "<template>\n  <v-card variant=\"tonal\">\n    <v-card-text class=\"d-flex align-center justify-space-between\">\n      <span>{{ msg.payload.label }}</span>\n      <v-chip\n        :color=\"msg.payload.value === 'TRUE' ? 'green' : 'grey'\"\n        variant=\"flat\"\n      >\n        {{ msg.payload.value || 'UNKNOWN' }}\n      </v-chip>\n    </v-card-text>\n  </v-card>\n</template>",
