    {
        "id": "40b71589d101899b",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "extract Last ERR",
        "func": "if (!msg.payload.lastErr) {\n    msg.payload = \"\";\n    return msg;\n}\nmsg.payload = [\n    msg.payload.lastErr.time,\n    msg.payload.lastErr.error,\n    msg.payload.lastErr.contextDecoded\n]\n    .filter(v => v !== null && v !== undefined && v !== \"\")\n    .join(\" | \");\nreturn msg;",
        "outputs": 1,
