    {
        "id": "1a31ee3e2f5fbd84",
        "type": "ui-template",
        "z": "3b521b08f4388c2f",
        "group": "87c6d1cd17eff6d5",
        "page": "",
        "ui": "",
        "name": "PacketLogTemplateWidget",
        "order": 13,
        "width": "8",
        "height": "5",
        "head": "",
        "format": "<template>\n  <v-card variant=\"tonal\" class=\"packet-log-card\">\n    <v-card-title>All Packet Log</v-card-title>\n    <v-card-text class=\"packet-log-body\">\n      <div v-if=\"!(msg.payload && msg.payload.rows && msg.payload.rows.length)\" class=\"packet-log-empty\">\n        No packets received yet.\n      </div>\n      <div v-else class=\"packet-log-list\">\n        <div\n          v-for=\"(row, index) in msg.payload.rows\"\n          :key=\"index\"\n          class=\"packet-log-row\"\n        >{{ row.raw || '-' }}</div>\n      </div>\n    </v-card-text>\n  </v-card>\n</template>\n\n<style>\n  .packet-log-card {\n    height: 100%;\n  }\n\n  .packet-log-body {\n    padding-top: 0;\n  }\n\n  .packet-log-list {\n    max-height: 26rem;\n    overflow-y: auto;\n    font-family: monospace;\n    line-height: 1.2;\n  }\n\n  .packet-log-row {\n    margin: 0;\n    padding: 0;\n    white-space: pre-wrap;\n    word-break: break-word;\n    font-size: 0.75rem;\n  }\n\n  .packet-log-empty {\n    color: rgba(0, 0, 0, 0.6);\n    font-size: 0.75rem;\n  }\n</style>",
        "storeOutMessages": true,
        "passthru": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 1340,
        "y": 40,
        "wires": [
            []
        ]
    },
