    {
        "id": "e328bd37e42d09ce",
        "type": "function",
        "z": "3b521b08f4388c2f",
        "name": "send TLM Interval 10",
        "func": "let interval = flow.get(\"tlmInterval\");\n\nif (!Number.isFinite(interval) || interval < 1) {\n    return null;\n}\n\nmsg.payload = \"SET,TELEMETRY,INTERVAL_S,\" + interval + \"\\n\";\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
