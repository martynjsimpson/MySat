        "func": "if (msg.type !== \"ERR\") {\n    return null;\n}\n\nlet errorLog = flow.get(\"errorLog\") || [];\n\nerrorLog.unshift({\n    raw: msg.raw || \"\"\n});\n\nerrorLog = errorLog.slice(0, 25);\nflow.set(\"errorLog\", errorLog);\n\nreturn {\n    payload: {\n        rows: errorLog\n    }\n};",
