        "format": "<template>\n  <v-card variant=\"tonal\" class=\"ack-log-card\">\n    <v-card-title>ACK Log</v-card-title>\n    <v-card-text class=\"ack-log-body\">\n      <div v-if=\"!(msg.payload && msg.payload.rows && msg.payload.rows.length)\" class=\"ack-log-empty\">\n        No acknowledgements received yet.\n      </div>\n      <div v-else class=\"ack-log-list\">\n        <div\n          v-for=\"(row, index) in msg.payload.rows\"\n          :key=\"index\"\n          class=\"ack-log-row\"\n        >{{ row.raw || '-' }}</div>\n      </div>\n    </v-card-text>\n  </v-card>\n</template>\n\n<style>\n  .ack-log-card {\n    height: 100%;\n    background: rgba(32, 96, 48, 0.24);\n  }\n\n  .ack-log-body {\n    padding-top: 0;\n  }\n\n  .ack-log-list {\n    max-height: 26rem;\n    overflow-y: auto;\n    font-family: monospace;\n    line-height: 1.2;\n  }\n\n  .ack-log-row {\n    margin: 0;\n    padding: 0;\n    white-space: pre-wrap;\n    word-break: break-word;\n    font-size: 0.75rem;\n  }\n\n  .ack-log-empty {\n    color: rgba(0, 0, 0, 0.6);\n    font-size: 0.75rem;\n  }\n</style>",
