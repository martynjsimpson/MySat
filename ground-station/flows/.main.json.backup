        "name": "ACK Log",
        "func": "if (msg.type !== \"ACK\") {\n    return null;\n}\n\nlet ackLog = flow.get(\"ackLog\") || [];\n\nackLog.unshift({\n    raw: msg.raw || \"\"\n});\n\nackLog = ackLog.slice(0, 25);\nflow.set(\"ackLog\", ackLog);\n\nreturn {\n    payload: {\n        rows: ackLog\n    }\n};",
